{
  "name": "@yaonyan/acp2openai-compatible",
  "version": "0.1.0",
  "description": "OpenAI-compatible API adapter for ACP (Agent Client Protocol) providers using the AI SDK. Framework-agnostic with built-in adapters for Hono, Express, and Web Standards.",
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yaonyan/acp2openai-compatible.git"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "build:workspace": "pnpm -r --if-present build",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "typecheck:workspace": "pnpm -r typecheck",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "pnpm run test:unit && pnpm run test:integration",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "example:hono": "ACP2OPENAI_CONFIG=examples/hono-server/acp2openai.config.json pnpm --filter acp2openai-example-hono-server dev",
    "example:hono:basic": "ACP2OPENAI_CONFIG=examples/hono-server/acp2openai.config.json pnpm --filter acp2openai-example-hono-server basic",
    "example:hono:ptc": "pnpm --filter acp2openai-example-hono-server ptc",
    "example:express": "pnpm --filter acp2openai-example-express-server dev",
    "client:stream": "pnpm --filter acp2openai-example-ai-sdk-client stream",
    "client:responses": "pnpm --filter acp2openai-example-ai-sdk-client responses",
    "client:anthropic": "pnpm --filter acp2openai-example-ai-sdk-client anthropic",
    "cli:build": "pnpm --filter @yaonyan/acp2openai-cli build",
    "cli:dev": "pnpm --filter @yaonyan/acp2openai-cli dev",
    "launch": "node scripts/launch-cli.mjs",
    "gateway:start": "bash scripts/start-acp2openai.sh",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "openai",
    "openai-compatible",
    "anthropic",
    "anthropic-compatible",
    "ai-sdk",
    "acp",
    "agent-client-protocol",
    "express",
    "hono",
    "cloudflare-workers",
    "vercel-ai-sdk",
    "chat-completions",
    "streaming",
    "sse"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "ai": "^6.0.116",
    "openai": "^6.27.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@ai-sdk/openai": "^3.0.52",
    "@mcpc-tech/acp-ai-provider": "^0.3.1",
    "@mcpc-tech/handle-sandbox": "^0.0.11",
    "@types/node": "^24.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "openai": "^6.27.0",
    "tsdown": "^0.21.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@agentclientprotocol/sdk": "*"
  },
  "peerDependenciesMeta": {
    "@agentclientprotocol/sdk": {
      "optional": true
    }
  }
}
