{
  "name": "@yaonyan/acp2openai-compatible",
  "version": "0.1.0",
  "description": "Provider-agnostic OpenAI/Anthropic-compatible adapter built on the AI SDK, with optional ACP and PTC integration packages.",
  "keywords": [
    "acp",
    "agent-client-protocol",
    "ai-sdk",
    "anthropic",
    "anthropic-compatible",
    "chat-completions",
    "cloudflare-workers",
    "express",
    "hono",
    "openai",
    "openai-compatible",
    "sse",
    "streaming",
    "vercel-ai-sdk"
  ],
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yaonyan/acp2openai-compatible.git"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "pnpm --filter @yaonyan/acp2openai-compatible --if-present run build:core",
    "build:core": "tsdown && tsc -p packages/core/tsconfig.json --emitDeclarationOnly && cp packages/core/dist/packages/core/src/index.d.ts dist/index.d.ts 2>/dev/null || true",
    "build:workspace": "pnpm -r --if-present build",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "typecheck:workspace": "pnpm -r --if-present typecheck",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "pnpm run test:unit && pnpm run test:integration",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "example:hono": "ACP2OPENAI_CONFIG=examples/hono-server/acp2openai.config.json pnpm --filter acp2openai-example-hono-server dev",
    "example:hono:basic": "ACP2OPENAI_CONFIG=examples/hono-server/acp2openai.config.json pnpm --filter acp2openai-example-hono-server basic",
    "example:hono:ptc": "pnpm --filter acp2openai-example-hono-server ptc",
    "example:express": "pnpm --filter acp2openai-example-express-server dev",
    "client:stream": "pnpm --filter acp2openai-example-ai-sdk-client stream",
    "client:responses": "pnpm --filter acp2openai-example-ai-sdk-client responses",
    "client:anthropic": "pnpm --filter acp2openai-example-ai-sdk-client anthropic",
    "cli:build": "pnpm --filter @yaonyan/acp2openai-cli build",
    "cli:dev": "pnpm --filter @yaonyan/acp2openai-cli dev",
    "launch": "node scripts/launch-cli.mjs",
    "gateway:start": "bash scripts/start-acp2openai.sh",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "ai": "^6.0.116",
    "openai": "^6.27.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@ai-sdk/openai": "^3.0.52",
    "@mcpc-tech/acp-ai-provider": "^0.3.1",
    "@mcpc-tech/handle-sandbox": "^0.0.11",
    "@types/node": "^24.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "openai": "^6.27.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "tsdown": "^0.21.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@agentclientprotocol/sdk": "*"
  },
  "peerDependenciesMeta": {
    "@agentclientprotocol/sdk": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.13.1"
}
