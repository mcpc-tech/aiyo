{
  "name": "@mcpc-tech/aiyo",
  "version": "0.1.0",
  "description": "Provider-agnostic OpenAI/Anthropic-compatible adapter built on the AI SDK, with optional ACP and PTC integration packages.",
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yaonyan/aiyo-compatible.git"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown && pnpm exec tsc -p tsconfig.json --emitDeclarationOnly && cp dist/packages/core/src/index.d.ts dist/index.d.ts && cp dist/packages/core/src/index.d.ts.map dist/index.d.ts.map",
    "dev": "tsdown --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "ai": "^6.0.116",
    "openai": "^6.27.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.87.0",
    "@mcpc-tech/acp-ai-provider": "^0.3.1",
    "@mcpc-tech/handle-sandbox": "^0.0.11",
    "@types/node": "^24.3.0",
    "tsdown": "^0.21.1",
    "typescript": "^5.9.2",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@agentclientprotocol/sdk": "*"
  },
  "peerDependenciesMeta": {
    "@agentclientprotocol/sdk": {
      "optional": true
    }
  }
}
