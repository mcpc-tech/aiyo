{
  "name": "@mcpc-tech/aiyo-cli",
  "version": "0.0.1-beta.4",
  "description": "CLI launcher for aiyo-compatible",
  "license": "Apache-2.0",
  "bin": {
    "aiyo": "./dist/bin.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./cli": {
      "import": "./dist/run-cli.mjs",
      "types": "./dist/run-cli.d.mts"
    },
    "./config": {
      "import": "./dist/config.mjs",
      "types": "./dist/config.d.mts"
    },
    "./proxy-server": {
      "import": "./dist/proxy-server.mjs",
      "types": "./dist/proxy-server.d.mts"
    },
    "./opencode": {
      "import": "./dist/opencode.mjs",
      "types": "./dist/opencode.d.mts"
    },
    "./claude-code": {
      "import": "./dist/claude-code.mjs",
      "types": "./dist/claude-code.d.mts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsx src/bin.ts",
    "launch": "tsx src/bin.ts launch",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.52",
    "@mcpc-tech/aiyo": "workspace:*",
    "@mcpc-tech/aiyo-acp": "workspace:*",
    "@mcpc-tech/aiyo-ptc": "workspace:*",
    "cac": "^7.0.0",
    "dotenv": "^17.4.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsdown": "^0.21.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=18"
  }
}
