{
  "name": "@yaonyan/acp2openai-cli",
  "version": "0.1.0",
  "description": "CLI launcher for acp2openai-compatible",
  "license": "MIT",
  "bin": {
    "acp2openai": "./dist/index.mjs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsdown && pnpm exec tsc -p tsconfig.json --emitDeclarationOnly && cp dist/packages/cli/src/index.d.ts dist/index.d.ts && cp dist/packages/cli/src/index.d.ts.map dist/index.d.ts.map",
    "dev": "tsx src/index.ts",
    "launch": "tsx src/index.ts launch",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@yaonyan/acp2openai-acp": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsdown": "^0.21.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=18"
  }
}
