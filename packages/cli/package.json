{
  "name": "@mcpc-tech/aiyo-cli",
  "version": "0.0.1-beta.2",
  "description": "CLI launcher for aiyo-compatible",
  "license": "Apache-2.0",
  "bin": {
    "aiyo": "./dist/index.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "scripts": {
    "build": "tsdown",
    "dev": "tsx src/index.ts",
    "launch": "tsx src/index.ts launch",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.52",
    "@mcpc-tech/aiyo": "workspace:*",
    "@mcpc-tech/aiyo-acp": "workspace:*",
    "@mcpc-tech/aiyo-ptc": "workspace:*",
    "dotenv": "^17.4.1"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsdown": "^0.21.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=18"
  }
}
